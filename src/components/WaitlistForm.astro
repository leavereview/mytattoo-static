---
/**
 * Founding-cohort waitlist capture form.
 *
 * Storage: posts to Formspree — the same hosted-form pattern already used by
 * contact.astro (this is a static site with no API layer). A `form_type`
 * hidden field distinguishes waitlist entries from contact messages.
 * TODO(review): create a dedicated Formspree form for the waitlist and swap
 * the endpoint below so entries land in their own inbox/export.
 *
 * Attribution captured silently on submit: utm_source / utm_medium /
 * utm_campaign (first-touch, persisted via sessionStorage so navigation
 * doesn't lose them), document.referrer, landing path, timestamp.
 *
 * Reusable: embed anywhere with <WaitlistForm id="unique-id" />.
 * The id must be unique per instance on a page.
 */
interface Props {
  id?: string;
}
const { id = 'waitlist' } = Astro.props;
---

<div class="waitlist-form card bg-gray-50 border border-gray-200" data-waitlist-form>
  <form data-waitlist class="space-y-4" novalidate>
    <div>
      <label for={`${id}-email`} class="block text-sm font-medium text-gray-700 mb-2">
        Email <span class="text-brand-red">*</span>
      </label>
      <input
        type="email"
        id={`${id}-email`}
        name="email"
        required
        autocomplete="email"
        class="input"
        placeholder="you@example.com"
      />
    </div>
    <div>
      <label for={`${id}-instagram`} class="block text-sm font-medium text-gray-700 mb-2">
        Instagram handle
      </label>
      <input
        type="text"
        id={`${id}-instagram`}
        name="instagram"
        autocomplete="off"
        class="input"
        placeholder="@yourhandle — optional"
      />
    </div>
    <button type="submit" class="btn-primary w-full">Join the founding cohort waitlist</button>
    <p data-waitlist-error class="hidden text-sm text-brand-red" role="alert">
      That didn't go through. Check your email address and try again.
    </p>
  </form>
  <p data-waitlist-success class="hidden text-brand-navy font-semibold" role="status">
    You're on the list. First 20 artists get the founder rate — we'll be in touch.
  </p>
</div>

<script>
  // First-touch attribution: capture UTM params + referrer + landing path once
  // per session, so navigating between pages doesn't lose them.
  const ATTR_KEY = 'mt_waitlist_attribution';
  try {
    if (!sessionStorage.getItem(ATTR_KEY)) {
      const params = new URLSearchParams(window.location.search);
      sessionStorage.setItem(ATTR_KEY, JSON.stringify({
        utm_source: params.get('utm_source') || '',
        utm_medium: params.get('utm_medium') || '',
        utm_campaign: params.get('utm_campaign') || '',
        referrer: document.referrer || '',
        landing_path: window.location.pathname,
      }));
    }
  } catch { /* sessionStorage unavailable — submit without attribution */ }

  document.querySelectorAll('[data-waitlist-form]').forEach((wrapper) => {
    const form = wrapper.querySelector('form[data-waitlist]') as HTMLFormElement | null;
    if (!form) return;
    const errorEl = wrapper.querySelector('[data-waitlist-error]') as HTMLElement;
    const successEl = wrapper.querySelector('[data-waitlist-success]') as HTMLElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      if (!form.reportValidity()) return;

      let attribution: Record<string, string> = {};
      try { attribution = JSON.parse(sessionStorage.getItem(ATTR_KEY) || '{}'); } catch {}

      const data = new FormData(form);
      const payload = {
        form_type: 'founding-waitlist',
        _subject: 'Founding cohort waitlist signup',
        email: data.get('email'),
        instagram: data.get('instagram') || '',
        ...attribution,
        submitted_at: new Date().toISOString(),
        submit_path: window.location.pathname,
      };

      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      button.disabled = true;
      try {
        const res = await fetch('https://formspree.io/f/xvzzgwwz', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } catch {
        errorEl.classList.remove('hidden');
        button.disabled = false;
      }
    });
  });
</script>
