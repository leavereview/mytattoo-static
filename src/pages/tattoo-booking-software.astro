  "@type": "Article",
  "headline": "Tattoo Booking Software: Complete Guide to Online Booking",
  "description": "Everything you need to know about online booking software for tattoo artists. Collect deposits, reduce no-shows, and let clients book 24/7.",
  "author": {
    "@type": "Organization",
    "name": "MyTattoo"
  },
  "datePublished": "2025-01-01",
  "dateModified": "2026-01-15"
};
---

<BaseLayout
  title="Tattoo Booking Software | 24/7 Online Booking & Automatic Deposits | MyTattoo"
  description="Let clients book online 24/7 and pay a deposit before the appointment is confirmed. Built for independent tattoo artists. Get started."
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

  <!-- Breadcrumbs with Schema -->
