---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbsEnhanced from '../components/seo/BreadcrumbsEnhanced.astro';
import FeaturedAnswer from '../components/seo/FeaturedAnswer.astro';
import StatisticsSection from '../components/seo/StatisticsSection.astro';
import ComparisonTable from '../components/seo/ComparisonTable.astro';
import FAQEnhanced from '../components/seo/FAQEnhanced.astro';

const schedulingStats = [
  { label: 'Client Account', value: 'None needed', context: 'Clients book with just their contact details' },
  { label: 'Deposit', value: 'Required to confirm', context: 'The appointment lands on your calendar only once the deposit clears' },
  { label: 'Platform Fee', value: '£0', context: 'You keep your deposit' },
  { label: 'Payments', value: 'Stripe', context: 'Card details never touch our servers' },
  { label: 'Access', value: 'Early access', context: 'Onboarding independent tattoo artists by invitation' }
];

const comparisonData = [
  {
    label: 'Online Booking (24/7)',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Email Notifications',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Real-Time Availability',
    values: [true, false, false],
    highlight: true
  },
  {
    label: 'Deposit-Gated Calendar',
    values: [true, false, false]
  },
  {
    label: 'Integrated Deposit Collection',
    values: [true, false, false]
  },
  {
    label: 'Automatic Buffer Time',
    values: [true, true, false]
  },
  {
    label: 'Client Self-Rescheduling',
    values: [true, false, false]
  },
  {
    label: 'No Client Account Needed',
    values: [true, false, false]
  },
  {
    label: 'Deposits Received List',
    values: [true, false, false]
  },
  {
    label: 'Mobile-Friendly Booking Page',
    values: [true, true, false]
  }
];

const faqItems = [
  {
    question: "What is tattoo scheduling software?",
    answer: "Tattoo scheduling software is a digital system that manages appointments for tattoo studios and artists, replacing paper diaries and DM-based booking with an online system. MyTattoo.Software's version is built around a simple flow: a client taps your Instagram bio link, lands on your branded booking page, and submits an intake form with reference images. You review the request, set a quote, and offer a time slot — the appointment only lands on your calendar once the client pays their deposit. Email notifications keep you and the client updated at every step.",
    links: [
      { text: 'View all features', url: '/features/' },
      { text: 'See pricing', url: '/pricing/' }
    ]
  },
  {
    question: "How does scheduling software reduce no-shows?",
    answer: "No-shows drop when clients have real financial commitment. Requiring a paid deposit before an appointment is confirmed means the client has already put money down, so they're far less likely to skip. MyTattoo.Software sends email notifications at every step — new request, offer sent, deposit paid — so you and the client always have a clear record of what's booked, without you having to chase anyone.",
    links: [
      { text: 'No-show reduction guide', url: '/blog/reduce-no-shows-tattoo-studio/' },
      { text: 'See all features', url: '/features/' }
    ]
  },
  {
    question: "Can clients book appointments themselves?",
    answer: "Yes. With MyTattoo.Software, clients tap your Instagram bio link, land on your branded booking page, and submit their contact details plus an intake form with reference images — no calling or messaging required. You review the request, set a quote, and offer a time slot; once the client pays the deposit, the appointment is confirmed and appears on your calendar. Your Instagram bio link, website, and Google listing can all point to the same booking page.",
    links: [
      { text: 'Booking software guide', url: '/tattoo-booking-software/' },
      { text: 'Get early access', url: '/contact/' }
    ]
  },
  {
    question: "Does scheduling software work for multiple artists?",
    answer: "Not currently — MyTattoo.Software today is built for the independent artist working solo: one calendar, one booking page. If you run a multi-artist studio, our studio software guide covers what to look for in the meantime.",
    links: [
      { text: 'See all features', url: '/features/' },
      { text: 'Studio software guide', url: '/tattoo-studio-software/' }
    ]
  },
  {
    question: "How much does tattoo scheduling software cost?",
    answer: "Tattoo scheduling software generally runs from roughly £20-80 a month depending on features, and some platforms charge per-booking fees instead of a flat rate — worth watching, since those add up as you get busier. MyTattoo.Software is currently in early access for independent tattoo artists: £0 platform fee, and no surcharge added to your client's deposit. Pricing is confirmed when you get in touch.",
    links: [
      { text: 'Pricing', url: '/pricing/' },
      { text: 'Get in touch', url: '/contact/' }
    ]
  },
  {
    question: "Can clients reschedule their own appointments?",
    answer: "Yes, good scheduling software lets clients reschedule within your policy limits (e.g., up to 48 hours before appointment). They click a reschedule link, see available alternative times, and select a new slot. You're notified automatically and the change appears in your calendar instantly. This saves back-and-forth messaging. You control whether deposits transfer to new appointments and how close to the appointment clients can reschedule.",
    links: [
      { text: 'Rescheduling policies', url: '/features/' },
      { text: 'Cancellation policies', url: '/blog/tattoo-deposit-guide/' }
    ]
  },
  {
    question: "What happens to cancelled appointments?",
    answer: "When an appointment is cancelled, you control the deposit policy — non-refundable, refundable with notice, or transferable to a new booking. You can set minimum notice periods (e.g., 48 hours) and enforce deposit forfeiture for late cancellations. The calendar updates automatically and shows the slot as available again.",
    links: [
      { text: 'See all features', url: '/features/' },
      { text: 'Deposit policies', url: '/blog/tattoo-deposit-guide/' }
    ]
  },
  {
    question: "How far in advance can clients book?",
    answer: "You control booking windows—common settings are 1-6 months in advance. Popular artists often open booking 2-3 months ahead, while guest artists might open booking for specific dates only. You can close booking temporarily (vacation, guest spot elsewhere, fully booked) while keeping your page active. Some studios use rolling availability (always show next 90 days) while others open specific booking windows quarterly.",
    links: [
      { text: 'Availability settings', url: '/features/' },
      { text: 'Guest artist guide', url: '/tattoo-artist-software/' }
    ]
  },
  {
    question: "Does scheduling sync with Google Calendar?",
    answer: "Not currently — appointments live in MyTattoo's own deposit-gated calendar. Two-way sync with Google Calendar or iCal isn't available yet.",
    links: [
      { text: 'See all features', url: '/features/' },
      { text: 'How booking works', url: '/features/' }
    ]
  },
  {
    question: "Can I set different availability for each artist?",
    answer: "MyTattoo.Software today manages one artist's calendar — there's no multi-artist availability management yet. If you're running a multi-artist studio, see our studio software guide for what to look for.",
    links: [
      { text: 'See all features', url: '/features/' },
      { text: 'Studio management guide', url: '/tattoo-studio-software/' }
    ]
  }
];

const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Tattoo Scheduling Software: Appointment Management for Studios",
  "description": "Complete guide to tattoo scheduling software. Online booking, calendar management, automated reminders, and multi-artist scheduling for tattoo studios.",
  "author": {
    "@type": "Organization",
    "name": "MyTattoo.Software"
  },
  "datePublished": "2026-01-18",
  "dateModified": "2026-01-18"
};
---

<BaseLayout
  title="Tattoo Scheduling Software (2026)"
  description="Let clients book online and pay a deposit before the appointment is confirmed. Built for independent tattoo artists. Get early access."
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

  <!-- Breadcrumbs -->
  <BreadcrumbsEnhanced
    site="tattoo"
    items={[
      { label: 'Home', href: '/' },
      { label: 'Tattoo Scheduling Software', href: '/tattoo-scheduling-software/' }
    ]}
  />

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy to-gray-900 text-white py-16">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-scheduling.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl">
        <span class="inline-block bg-brand-red/20 text-brand-red-light px-3 py-1 rounded-full text-sm mb-4">Appointment Management</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Tattoo Scheduling Software</h1>
        <p class="text-xl text-gray-300 mb-4">
          <strong>Tattoo scheduling software</strong> eliminates the chaos of manual booking. Let clients book online, send automatic reminders, and protect your time with deposits—all from one system.
        </p>
        <p class="text-gray-400 mb-8">Last updated: January 2026 | Reading time: 8 minutes</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact/" class="btn-primary text-lg px-8 py-4">Get early access</a>
          <a href="#what-is" class="btn-secondary text-lg px-8 py-4">Read the Guide</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Answer -->
  <FeaturedAnswer question="What is tattoo scheduling software?">
    Tattoo scheduling software is a digital system that manages appointments for tattoo studios and artists. It handles online booking, calendar management, reminders, and deposit collection. MyTattoo.Software's version is built for the independent artist: clients book via your Instagram bio link, submit an intake form, and pay a deposit before the appointment is confirmed — so the software prevents double-bookings and lets clients book 24/7, without you chasing anyone.
  </FeaturedAnswer>

  <!-- Statistics Section -->
  <StatisticsSection
    site="tattoo"
    pageUrl="https://mytattoo.software/tattoo-scheduling-software/"
    title="Tattoo Scheduling Software Impact"
    stats={schedulingStats}
  />

  <!-- Table of Contents -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <h2 class="text-xl font-bold text-brand-navy mb-4">In This Guide</h2>
          <ul class="grid md:grid-cols-2 gap-2 text-gray-700">
            <li><a href="#what-is" class="hover:text-brand-red">→ What Is Scheduling Software?</a></li>
            <li><a href="#features" class="hover:text-brand-red">→ Essential Features</a></li>
            <li><a href="#benefits" class="hover:text-brand-red">→ Benefits for Studios</a></li>
            <li><a href="#multi-artist" class="hover:text-brand-red">→ Multi-Artist Management</a></li>
            <li><a href="#choosing" class="hover:text-brand-red">→ Choosing Software</a></li>
            <li><a href="#faq" class="hover:text-brand-red">→ FAQ</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">

        <h2 id="what-is" class="text-3xl font-bold text-brand-navy mb-6">What Is Tattoo Scheduling Software?</h2>
        <p class="text-lg text-gray-600 mb-6">
          <strong>Tattoo scheduling software</strong> is a digital system that manages appointments for tattoo studios and individual artists. It replaces paper diaries, phone-based booking, and scattered DM conversations with a centralised calendar that clients can book directly.
        </p>
        <p class="text-gray-600 mb-8">
          Beyond basic scheduling, modern tattoo software integrates deposit collection, automated reminders, client records, and multi-artist management. The goal is simple: spend less time on admin and more time tattooing.
        </p>

        <h2 id="features" class="text-3xl font-bold text-brand-navy mt-12 mb-6">Essential Scheduling Features</h2>

        <div class="grid md:grid-cols-2 gap-6 my-8">
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-brand-navy mb-2">Online Booking Portal</h3>
            <p class="text-gray-700 text-sm">A branded booking page where clients see real availability, select services, and confirm appointments without calling or messaging.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-brand-navy mb-2">Calendar Management</h3>
            <p class="text-gray-700 text-sm">Visual calendar showing all appointments, blocked time, and availability. Easy to reschedule by dragging appointments.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-brand-navy mb-2">Email Notifications</h3>
            <p class="text-gray-700 text-sm">Automatic emails on every step — new request, offer sent, deposit paid.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-brand-navy mb-2">Deposit Integration</h3>
            <p class="text-gray-700 text-sm">Collect deposits at time of booking to secure appointments and protect against last-minute cancellations.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-brand-navy mb-2">Service Configuration</h3>
            <p class="text-gray-700 text-sm">Set up different appointment types with custom durations, prices, and deposit requirements—consultations, small pieces, full sessions.</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-lg">
            <h3 class="font-bold text-brand-navy mb-2">Buffer Time</h3>
            <p class="text-gray-700 text-sm">Automatically add setup and cleanup time between appointments so you're never running behind.</p>
          </div>
        </div>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Advanced Features</h3>
        <ul class="space-y-2 mb-8">
          <li><strong>Waitlist management:</strong> Capture interested clients when fully booked</li>
          <li><strong>Recurring appointments:</strong> Set up regular sessions for large projects</li>
          <li><strong>Calendar sync:</strong> Two-way sync with Google Calendar or iCal</li>
          <li><strong>Time-off management:</strong> Block holidays, conventions, or personal time</li>
          <li><strong>Cancellation policies:</strong> Enforce and communicate your policies</li>
          <li><strong>Confirmation workflows:</strong> Require client confirmation before appointments</li>
        </ul>

        <h2 id="benefits" class="text-3xl font-bold text-brand-navy mt-12 mb-6">Benefits for Tattoo Studios</h2>

        <div class="bg-bone-hi border-l-4 border-brand-red p-4 my-6">
          <p class="font-bold text-brand-navy">Time is money</p>
          <p>Every DM thread and phone call about availability is time not spent tattooing. Moving booking, quoting, and deposits into one online flow gives that time back.</p>
        </div>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Operational Benefits</h3>
        <ul class="space-y-3 mb-6">
          <li><strong>24/7 booking:</strong> Clients book when it's convenient for them, not just during shop hours</li>
          <li><strong>Zero double-bookings:</strong> Real-time availability prevents scheduling conflicts</li>
          <li><strong>Reduced no-shows:</strong> Automated reminders and deposits protect your time</li>
          <li><strong>Less phone time:</strong> Fewer calls and messages about availability</li>
          <li><strong>Professional image:</strong> Modern booking experience impresses clients</li>
        </ul>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Financial Benefits</h3>
        <ul class="space-y-3 mb-8">
          <li><strong>Protected revenue:</strong> Deposits ensure client commitment</li>
          <li><strong>Optimised schedule:</strong> Fill gaps efficiently, maximise billable hours</li>
          <li><strong>Reduced admin costs:</strong> Less time = lower overhead</li>
          <li><strong>Better forecasting:</strong> See upcoming revenue at a glance</li>
        </ul>

        <!-- Calculator Callout -->
        <div style="background: linear-gradient(135deg, #F4E4E1 0%, #F3ECDD 100%); border-left: 4px solid #A62B22; padding: 1.5rem; border-radius: 0.5rem; margin: 2rem 0;">
          <div style="display: flex; align-items: start; gap: 1rem;">
            <div style="flex-shrink: 0; width: 48px; height: 48px; background: #A62B22; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center;">
              <svg style="width: 28px; height: 28px; color: white;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div style="flex: 1;">
              <h3 style="font-size: 1.25rem; font-weight: 700; color: #17120E; margin: 0 0 0.5rem 0;">Maximize Your Billable Hours</h3>
              <p style="color: #241B14; margin: 0 0 1rem 0; line-height: 1.6;">See how schedule optimization impacts your revenue. Our calculator shows how improving your booking rate translates into additional annual income.</p>
              <a href="/tattoo-studio-calculator/" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #A62B22; font-weight: 600; text-decoration: none;">
                Calculate Your Booking Potential →
              </a>
            </div>
          </div>
        </div>

        <h2 id="multi-artist" class="text-3xl font-bold text-brand-navy mt-12 mb-6">Multi-Artist Studio Management</h2>
        <p class="text-gray-600 mb-6">
          MyTattoo.Software today is built for the independent artist working solo — one calendar, one booking page, deposit-secured from request to confirmed appointment. There's no multi-artist studio management yet. If you're comparing options for a multi-artist studio, here's what to look for in scheduling software generally.
        </p>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Individual Artist Features</h3>
        <ul class="space-y-2 mb-6">
          <li><strong>Personal calendars:</strong> Each artist should manage their own schedule</li>
          <li><strong>Style-based booking:</strong> Clients should be able to filter artists by specialty</li>
          <li><strong>Custom availability:</strong> Different working hours for each artist</li>
          <li><strong>Portfolio integration:</strong> Each artist's work shown on the booking page</li>
          <li><strong>Individual pricing:</strong> Rates set per artist where they vary</li>
        </ul>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Studio-Level Management</h3>
        <ul class="space-y-2 mb-8">
          <li><strong>Unified view:</strong> All artist schedules visible in one place</li>
          <li><strong>Workstation management:</strong> Conflict prevention when artists share space</li>
          <li><strong>Reporting:</strong> Bookings and revenue tracked by artist</li>
          <li><strong>Consistent policies:</strong> Standard deposits and cancellation rules across artists</li>
          <li><strong>Guest artist support:</strong> Easy to add temporary artists</li>
        </ul>

      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-5xl mx-auto">
        <ComparisonTable
          title="Scheduling Software vs Generic Booking vs Manual Methods"
          headers={['MyTattoo.Software', 'Generic Booking', 'Manual/DMs']}
          rows={comparisonData}
        />
      </div>
    </div>
  </section>

  <!-- Main Content Continued -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">

        <h2 id="choosing" class="text-3xl font-bold text-brand-navy mt-12 mb-6">Choosing Scheduling Software</h2>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Must-Have Features</h3>
        <ul class="space-y-2 mb-6">
          <li><strong>Online booking:</strong> Clients should book without messaging you</li>
          <li><strong>Automated reminders:</strong> Email before appointments</li>
          <li><strong>Deposit collection:</strong> Integrated payment at booking</li>
          <li><strong>Mobile access:</strong> Manage schedule from your phone</li>
          <li><strong>Calendar sync:</strong> Integrate with your personal calendar</li>
          <li><strong>Buffer time:</strong> Automatic gaps between appointments</li>
        </ul>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Nice-to-Have Features</h3>
        <ul class="space-y-2 mb-6">
          <li>Design reference upload at booking</li>
          <li>Client intake forms and waivers</li>
          <li>Multi-session project tracking</li>
          <li>Reporting and analytics</li>
          <li>Marketing tools (email campaigns)</li>
        </ul>

        <h3 class="text-xl font-bold text-brand-navy mt-8 mb-4">Red Flags</h3>
        <ul class="space-y-2 mb-8">
          <li>Per-booking fees that increase with volume</li>
          <li>No mobile app or mobile-optimized interface</li>
          <li>Clunky deposit collection</li>
          <li>No automated reminders</li>
          <li>Desktop-only with no cloud access</li>
        </ul>

        <p>Related: <a href="/tattoo-studio-software/" class="text-brand-red hover:underline">Tattoo Studio Software</a> | <a href="/tattoo-booking-software/" class="text-brand-red hover:underline">Tattoo Booking Software</a> | <a href="/tattoo-booking-app/" class="text-brand-red hover:underline">Tattoo Booking App</a></p>

      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FAQEnhanced
    site="tattoo"
    pageUrl="https://mytattoo.software/tattoo-scheduling-software/"
    title="Frequently Asked Questions About Tattoo Scheduling Software"
    faqs={faqItems}
  />

  <!-- CTA Section -->
  <section class="section bg-gradient-to-r from-brand-red to-blood-deep text-white">
    <div class="container-custom text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Take Control of Your Schedule?</h2>
      <p class="text-xl mb-8 opacity-90">Stop the DM chaos. Let clients book online, send automatic reminders, and protect your time with deposits—all in one system.</p>
      <a href="/contact/" class="btn bg-white text-brand-red hover:bg-gray-100 text-lg px-8 py-4">Get early access</a>
      <p class="text-sm mt-4 opacity-75">MyTattoo is in early access for independent tattoo artists.</p>
    </div>
  </section>

  <!-- Related Content -->
  <section class="section bg-gray-50">
    <div class="container-custom">
      <h2 class="text-2xl font-bold text-brand-navy mb-8 text-center">Related Guides</h2>
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <a href="/tattoo-studio-software/" class="card p-6 hover:shadow-lg transition-shadow">
          <h3 class="font-bold text-brand-navy mb-2">Tattoo Studio Software</h3>
          <p class="text-gray-600 text-sm">Complete studio management</p>
        </a>
        <a href="/tattoo-booking-app/" class="card p-6 hover:shadow-lg transition-shadow">
          <h3 class="font-bold text-brand-navy mb-2">Tattoo Booking App</h3>
          <p class="text-gray-600 text-sm">Mobile booking for clients</p>
        </a>
        <a href="/blog/reduce-no-shows-tattoo-studio/" class="card p-6 hover:shadow-lg transition-shadow">
          <h3 class="font-bold text-brand-navy mb-2">Reducing No-Shows</h3>
          <p class="text-gray-600 text-sm">Protect your bookings</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
