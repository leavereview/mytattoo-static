---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="Pricing | MyTattoo.Software" description="Deposit-secured booking for independent tattoo artists. No platform fee, no per-booking fees, no subscription — connect Stripe and keep every deposit.">
  <!-- Breadcrumbs -->
  <div class="bg-gray-100 py-3">
    <div class="container-custom">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Pricing' }
      ]} />
    </div>
  </div>

  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy to-gray-900 text-white py-16">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-pricing.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative">
      <div class="max-w-3xl text-center mx-auto">
        <span class="inline-block bg-brand-red/20 text-brand-red-light px-3 py-1 rounded-full text-sm mb-4">Pricing</span>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Pricing</h1>
        <p class="text-xl text-gray-300">MyTattoo is deposit-secured booking for independent tattoo artists.</p>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-brand-navy mb-4">No platform fee. Keep every deposit.</h2>
        <p class="text-lg text-gray-600 mb-6">
          MyTattoo is free while we're in early access — no platform fee, no per-booking fee, and no subscription. Connect your own Stripe, set your deposit, and it lands straight in your account (you just pay Stripe's standard card processing, like any checkout). <a href="/contact/" class="text-brand-red hover:underline">Get in touch</a> if you've any questions.
        </p>
        <p class="text-lg text-gray-600 mb-8">
          Most booking platforms take a percentage of your work — typically 3–5% of every booking, and marketplaces
          like Booksy take up to 30% of a new client's booking. On a £400 tattoo that's £12 to £120 out of your pocket.
          MyTattoo takes <strong>nothing</strong>. Your client pays you for the tattoo; we never touch it.
        </p>
        <div class="card border-2 border-brand-red text-left max-w-md mx-auto mb-8">
          <h3 class="text-xl font-bold text-brand-navy mb-4">What's included</h3>
          <ul class="space-y-2 text-sm text-gray-700">
            <li>✓ Instagram bio-link booking page</li>
            <li>✓ Reference images + intake form</li>
            <li>✓ Deposit collection via Stripe</li>
            <li>✓ Deposit-gated calendar — no booking without a paid deposit</li>
            <li>✓ Email notifications on request, offer, and paid deposit</li>
            <li>✓ £0 platform fee — you keep your deposit</li>
          </ul>
        </div>
        <a href="https://app.mytattoo.software/signin" class="btn-primary text-lg px-8 py-4">Get started</a>

        <p class="mt-8 text-sm text-gray-500 max-w-lg mx-auto">
          <strong class="text-brand-navy">Will this stay free?</strong> We'll introduce paid plans in future — we're
          being upfront about that rather than springing it on you. If we do, you'll get
          <a href="/terms/" class="text-brand-red hover:underline">at least 30 days' notice</a> before any charge.
        </p>

        <p class="mt-6 text-sm text-gray-500">
          Read more about the <a href="/tattoo-booking-software/" class="text-brand-red hover:underline">booking software</a>, see it built for <a href="/tattoo-artist-software/" class="text-brand-red hover:underline">independent artists</a>, or browse the <a href="/tattoo-software-comparison/" class="text-brand-red hover:underline">software comparison</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
