// Feature-by-feature comparison across the main platforms tattoo artists actually consider.
// Columns: Feature | MyTattoo | Booksy | Mindbody | Square Appointments
const comparisonData = [
  { label: 'Built specifically for tattoo studios', values: [true, false, false, false], highlight: true },
  { label: 'Tattoo consent & medical-history forms', values: [true, false, false, false], highlight: true },
  { label: 'Reference image upload at booking', values: [true, false, false, false], highlight: true },
  { label: 'Automatic deposit collection', values: [true, true, true, true] },
  { label: 'Custom deposit & cancellation policies', values: [true, true, true, true] },
  { label: 'SMS & email reminders', values: [true, true, true, true] },
  { label: '24/7 online booking', values: [true, true, true, true] },
  { label: 'Instagram bio booking link', values: [true, true, true, true] },
  { label: 'Multi-artist studio calendars', values: [true, true, true, true] },
  { label: 'No marketplace commission on new-client bookings', values: [true, false, false, true], highlight: true },
  { label: 'Free entry tier', values: [false, false, false, true] },
];

const faqItems = [
  {
    question: "What is the best tattoo studio software?",
