---
import BaseLayout from '../layouts/BaseLayout.astro';

// Software Application Schema — honest to the current product (no fabricated
// ratings/reviews, no fictional free trial). Access is open, self-serve signup.
const softwareApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": "https://mytattoo.software/#software",
  "name": "MyTattoo.Software",
  "alternateName": "MyTattoo",
  "description": "Deposit-secured booking for independent tattoo artists. Turn your Instagram bio link into a reference-attached booking, confirmed by a deposit that lands the appointment on your calendar.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "featureList": [
    "Instagram bio-link booking page",
    "No client account required",
    "Reference images + intake questions",
    "Artist-set time-slot offers",
    "Deposit collection via Stripe",
    "Deposit-gated calendar (appointment only after the deposit clears)",
    "Email notifications for request, offer and paid deposit",
    "Cancel / reschedule",
    "Deposits-received list"
  ],
  "url": "https://mytattoo.software",
  "applicationSubCategory": "Tattoo Booking",
  "audience": {
    "@type": "BusinessAudience",
    "audienceType": "Independent Tattoo Artists"
  }
};

// Real product features (what the app does today).
const features = [
  { icon: 'calendar', title: 'Bio-link booking', description: 'A branded page for your Instagram bio. Clients tap it and request a booking — no app to download, no account to create.' },
  { icon: 'credit-card', title: 'Deposit-secured', description: 'The appointment only lands on your calendar once the deposit has cleared. Card details go straight to Stripe, never your servers.' },
  { icon: 'users', title: 'References + intake', description: 'Clients attach reference images and answer your questions up front, so you have what you need before you quote.' },
  { icon: 'bell', title: 'Kept in the loop', description: 'Automatic emails at every step — a new request, an offer sent, and a deposit paid — for you and the client.' },
  { icon: 'mobile', title: 'Built for your phone', description: 'Review requests, offer times, and manage your calendar from the palm of your hand.' },
  { icon: 'chart', title: 'Deposits at a glance', description: 'Every deposit you have taken in one simple list. No spreadsheets, no chasing.' }
];

// Honest "why", not fabricated testimonials (the product is pre-launch).
const reasons = [
  { title: 'Stop chasing deposits', body: 'The deposit is paid before the appointment even exists — no awkward DMs, no "did you send it yet?".' },
  { title: 'Cut the no-shows', body: 'A paid deposit is skin in the game. Fewer ghosted slots, more filled chairs.' },
  { title: 'No friction for clients', body: 'They book from your link in seconds — nothing to install, no password to forget.' }
];

// Honest product facts, not unverifiable vanity metrics.
const stats = [
  { number: '£0', label: 'Platform fee — you keep your deposit' },
  { number: 'No account', label: 'Clients just tap your link' },
  { number: 'Deposit-first', label: 'No booking without a paid deposit' },
  { number: 'Stripe', label: 'Secure card payments' }
];

const screenshots = [
  { src: '/images/app/booking-page.png', alt: 'MyTattoo client booking page shown on a mobile phone', caption: 'Your booking page' },
  { src: '/images/app/offer-deposit.png', alt: 'Deposit-secured booking offer screen shown to a client', caption: 'Deposit-secured offer' },
  { src: '/images/app/admin-inbox.png', alt: "Artist's inbox of incoming booking requests", caption: 'Your requests inbox' },
  { src: '/images/app/admin-calendar.png', alt: "Artist's appointment calendar of confirmed bookings", caption: 'Your calendar' }
];
---

<BaseLayout title="Deposit-secured tattoo booking from your bio link | MyTattoo" description="Turn your Instagram bio link into a deposit-secured, reference-attached tattoo booking. Cut no-shows and stop chasing deposits — no client app, no account.">
  <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />

  <section class="relative overflow-hidden bg-gradient-to-br from-brand-navy via-brand-navy to-gray-900 text-white">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('/images/hero-tattoo.jpg'); background-size: cover; background-position: center;"></div>
    </div>
    <div class="container-custom relative py-20 md:py-32">
      <div class="max-w-3xl">
        <span class="badge-primary mb-6">For independent tattoo artists</span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6">
          Your bio link does the <span class="text-brand-red">booking</span> now
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-8 leading-relaxed">
          Turn your Instagram bio link into a deposit-secured, reference-attached booking. No DMs, no chasing, no no-shows.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://app.mytattoo.software/signin" class="btn-primary text-lg px-8 py-4">Get started</a>
          <a href="/tattoo-booking-software/" class="btn-secondary text-lg px-8 py-4">See how it works</a>
        </div>
        <p class="mt-6 text-sm text-gray-400">Deposit-secured · no client account · no surcharge</p>
      </div>
    </div>
  </section>

  <section class="section bg-bone">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="badge-primary mb-4">Product tour</span>
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">See it in action</h2>
        <p class="text-lg text-text-secondary">From the first booking request to a paid deposit on the calendar — here's the real app, screen by screen.</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 max-w-5xl mx-auto">
        {screenshots.map((shot) => (
          <div>
            <div class="aspect-[780/1688] rounded-2xl overflow-hidden bg-ink border border-paper-line shadow-lg">
              <img
                src={shot.src}
                alt={shot.alt}
                width="780"
                height="1688"
                loading="lazy"
                class="w-full h-full object-cover object-top"
              />
            </div>
            <p class="mt-3 text-center font-mono text-xs md:text-sm uppercase tracking-wide text-sepia-deep">{shot.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-gray-50 border-b border-gray-100">
    <div class="container-custom">
      <p class="text-center text-sm text-gray-500 uppercase tracking-wider mb-8">Booking, minus the chasing</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {stats.map((stat) => (
          <div>
            <div class="text-2xl md:text-3xl font-bold text-brand-navy">{stat.number}</div>
            <div class="text-sm text-gray-600 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="badge-primary mb-4">Features</span>
        <h2 class="text-3xl md:text-5xl font-bold text-brand-navy mb-6">Everything the booking needs, nothing it doesn't</h2>
        <p class="text-xl text-gray-600">From a tap on your bio link to a deposit-paid appointment on your calendar.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="card group">
            <div class="w-12 h-12 rounded-xl bg-brand-red-light flex items-center justify-center mb-4 group-hover:bg-brand-red transition-colors">
              <svg class="w-6 h-6 text-brand-red group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {feature.icon === 'calendar' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />}
                {feature.icon === 'users' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />}
                {feature.icon === 'credit-card' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />}
                {feature.icon === 'chart' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />}
                {feature.icon === 'bell' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />}
                {feature.icon === 'mobile' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />}
              </svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-2">{feature.title}</h3>
            <p class="text-gray-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="badge-primary mb-4">How it works</span>
          <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
            Three steps, and you're chasing nothing
          </h2>
          <ul class="space-y-6 mb-8">
            <li class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-red text-white font-bold flex items-center justify-center">1</span>
              <span class="text-gray-700"><strong class="text-brand-navy">Share your link.</strong> Put your MyTattoo link in your Instagram bio. Clients tap it and land on your branded booking page — no app, no account.</span>
            </li>
            <li class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-red text-white font-bold flex items-center justify-center">2</span>
              <span class="text-gray-700"><strong class="text-brand-navy">They book + pay a deposit.</strong> They send references, pick a time you offered, and pay the deposit through Stripe.</span>
            </li>
            <li class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-red text-white font-bold flex items-center justify-center">3</span>
              <span class="text-gray-700"><strong class="text-brand-navy">It lands on your calendar.</strong> Only once the deposit clears — so no-shows drop, and you never chase a payment again.</span>
            </li>
          </ul>
          <a href="/tattoo-booking-software/" class="btn-primary">
            See how it works
          </a>
        </div>
        <div class="relative">
          <img
            src="/images/feature-studio.jpg"
            alt="Independent tattoo artist at work"
            class="rounded-2xl shadow-2xl"
          />
          <div class="absolute -bottom-6 -left-6 bg-white rounded-xl shadow-lg p-4 hidden md:block">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-brand-red-light flex items-center justify-center">
                <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <div class="font-bold text-brand-navy">Deposit paid</div>
                <div class="text-sm text-gray-500">Booking confirmed</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-gray-50">
    <div class="container-custom">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="badge-primary mb-4">Explore</span>
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Built for how artists actually book</h2>
        <p class="text-lg text-gray-600">However people search for it — booking, scheduling, an app on your phone — it's the same deposit-secured flow.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/tattoo-booking-software/" class="card hover:shadow-lg transition-shadow group">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4 group-hover:bg-brand-red transition-colors">
            <svg class="w-5 h-5 text-brand-red group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-brand-navy mb-2">Tattoo Booking Software</h3>
          <p class="text-gray-600 text-sm">Online booking your clients can use 24/7, with a deposit collected at checkout.</p>
        </a>
        <a href="/tattoo-scheduling-software/" class="card hover:shadow-lg transition-shadow group">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4 group-hover:bg-brand-red transition-colors">
            <svg class="w-5 h-5 text-brand-red group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-brand-navy mb-2">Tattoo Scheduling Software</h3>
          <p class="text-gray-600 text-sm">You set the times on offer; the client picks one and secures it with a deposit.</p>
        </a>
        <a href="/tattoo-booking-app/" class="card hover:shadow-lg transition-shadow group">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4 group-hover:bg-brand-red transition-colors">
            <svg class="w-5 h-5 text-brand-red group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-brand-navy mb-2">Tattoo Booking App</h3>
          <p class="text-gray-600 text-sm">Mobile-first for on-the-go artists. Manage everything from your phone.</p>
        </a>
        <a href="/tattoo-artist-software/" class="card hover:shadow-lg transition-shadow group">
          <div class="w-10 h-10 rounded-lg bg-brand-red-light flex items-center justify-center mb-4 group-hover:bg-brand-red transition-colors">
            <svg class="w-5 h-5 text-brand-red group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-brand-navy mb-2">Tattoo Artist Software</h3>
          <p class="text-gray-600 text-sm">Purpose-built for the independent artist — bookings, references, and deposits in one place.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section bg-brand-navy text-white">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="bg-white/10 text-white px-3 py-1 rounded-full text-sm font-medium mb-4 inline-block">Why MyTattoo</span>
        <h2 class="text-3xl md:text-5xl font-bold mb-6">Built to end the deposit chase</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {reasons.map((reason) => (
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
            <h3 class="text-xl font-bold mb-3">{reason.title}</h3>
            <p class="text-gray-300 leading-relaxed">{reason.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto text-center">
        <span class="badge bg-brand-red-light text-brand-red mb-4">Free planning tool</span>
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">
          Work out what no-shows cost you
        </h2>
        <p class="text-xl text-text-secondary mb-8">
          Model your income, costs, and the price of an empty chair. See exactly how your booking rate, deposit policy, and pricing shape what you actually take home.
        </p>
        <div class="grid md:grid-cols-3 gap-6 mb-8">
          <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
            <div class="w-12 h-12 bg-brand-red rounded-lg flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="font-bold text-brand-navy mb-2">Income modelling</h3>
            <p class="text-sm text-text-secondary">Calculate your real take-home after costs, commissions, and booking gaps</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
            <div class="w-12 h-12 bg-brand-red rounded-lg flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="font-bold text-brand-navy mb-2">No-show cost</h3>
            <p class="text-sm text-text-secondary">See how utilisation rates and no-shows eat into your annual income</p>
          </div>
          <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
            <div class="w-12 h-12 bg-brand-red rounded-lg flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <h3 class="font-bold text-brand-navy mb-2">Growth projections</h3>
            <p class="text-sm text-text-secondary">Model your income over 6–24 months with seasonality built in</p>
          </div>
        </div>
        <a href="/tattoo-studio-calculator/" class="btn-primary text-lg px-8 py-4">
          Try the free calculator
        </a>
      </div>
    </div>
  </section>

  <section class="section bg-gradient-to-r from-brand-red to-brand-red-dark text-white">
    <div class="container-custom text-center">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">Ready to stop chasing deposits?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">Put your link in your bio and let the deposits do the confirming.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://app.mytattoo.software/signin" class="btn bg-white text-brand-red hover:bg-gray-100 text-lg px-8 py-4">Get started</a>
        <a href="/tattoo-booking-software/" class="btn bg-transparent border-2 border-white text-white hover:bg-white/10 text-lg px-8 py-4">See how it works</a>
      </div>
    </div>
  </section>
</BaseLayout>
